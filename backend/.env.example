# ── FIFA World Cup 2026 backend configuration ────────────────────────────────

# Data provider: "thesportsdb" (free, real WC 2026 data) or "apifootball".
PROVIDER=thesportsdb

# ── TheSportsDB (free) ───────────────────────────────────────────────────────
# "3" is the public no-signup test key. For higher rate limits / premium
# endpoints, use your own (low-cost) Patreon key.
THESPORTSDB_BASE=https://www.thesportsdb.com/api/v1/json
THESPORTSDB_KEY=3
THESPORTSDB_LEAGUE_ID=4429   # FIFA World Cup
THESPORTSDB_SEASON=2026

# ── API-Football (optional alternate) ────────────────────────────────────────
# NOTE: the free tier does NOT include WC 2026 (free = seasons 2022–2024). Use a
# paid plan for 2026, or set WC_SEASON=2022 to preview real historical data.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE=https://v3.football.api-sports.io
WC_LEAGUE_ID=1
WC_SEASON=2026

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000
